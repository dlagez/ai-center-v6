APP_NAME=ai-center-v6
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
DASHSCOPE_API_KEY=your-dashscope-key
LLM_DEFAULT_MODEL=openai/gpt-4o
LLM_VISION_MODEL=dashscope/qwen-vl-plus-latest
LLM_API_BASE=
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT=60
LLM_TEMPERATURE=0
MEDIA_FFMPEG_BINARY=ffmpeg
EMBEDDING_MODEL=openai/text-embedding-v3
EMBEDDING_BATCH_SIZE=32
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/ai_center
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=ai-center
SQL_AGENT_DIALECT=sqlite
SQL_AGENT_DEFAULT_DB_PATH=
SQL_AGENT_MAX_ROWS=20
SQL_AGENT_MAX_RETRIES=2
SQL_AGENT_MYSQL_HOST=
SQL_AGENT_MYSQL_PORT=3306
SQL_AGENT_MYSQL_USER=
SQL_AGENT_MYSQL_PASSWORD=
SQL_AGENT_MYSQL_DATABASE=
KNOWLEDGE_CHUNK_SIZE=1200
KNOWLEDGE_CHUNK_OVERLAP=200
QDRANT_PATH=./data/qdrant
QDRANT_COLLECTION=default_knowledge
EMBEDDING_DIMENSION=1536

LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_DEBUG=false
LANGFUSE_FLUSH_AT=1
